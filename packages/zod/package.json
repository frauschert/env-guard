{
  "name": "@frauschert/env-guard-zod",
  "version": "1.0.0",
  "description": "Zod schema adapter for env-guard — validate environment variables with Zod schemas",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "env",
    "environment",
    "validation",
    "typescript",
    "type-safe",
    "zod"
  ],
  "license": "MIT",
  "peerDependencies": {
    "zod": ">=3.0.0"
  },
  "dependencies": {
    "@frauschert/env-guard": "*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0",
    "@types/node": "^22.0.0"
  }
}
